{
  "name": "@ekajaya/admin",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run dev:app & bun run dev:studio & wait",
    "dev:app": "vite dev",
    "dev:studio": "bun --env-file .dev.vars drizzle-kit studio",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "db:generate": "bun --env-file .dev.vars drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply portfolio-db --remote --config wrangler.production.jsonc",
    "db:push": "bun --env-file .dev.vars drizzle-kit push",
    "db:studio": "bun --env-file .dev.vars drizzle-kit studio"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.18",
    "@editorjs/code": "^2.9.4",
    "@editorjs/delimiter": "^1.4.2",
    "@editorjs/editorjs": "^2.31.6",
    "@editorjs/header": "^2.8.9",
    "@editorjs/image": "^2.10.3",
    "@editorjs/list": "^2.0.9",
    "@editorjs/quote": "^2.7.6",
    "@editorjs/table": "^2.4.5",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "better-auth": "^1.6.18",
    "better-auth-cloudflare": "^0.3.0",
    "drizzle-orm": "^1.0.0-rc.3",
    "editorjs-react": "^0.1.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20250605.0",
    "drizzle-kit": "^1.0.0-rc.3",
    "@vitejs/plugin-react": "^4.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "vite": "^6.3.0",
    "vite-tsconfig-paths": "^5.1.0",
    "wrangler": "^4.34.0"
  }
}
