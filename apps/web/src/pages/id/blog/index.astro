---
import Layout from '@/layouts/BaseLayout.astro';

const API_URL = process.env.PUBLIC_API_URL || 'http://localhost:5173';

interface Post {
  id: string;
  slug: string;
  language: string;
  title: string;
  description: string;
  content: string;
  thumbnailKey: string | null;
  author: string;
  tags: string;
  publishedAt: number | null;
}

let posts: Post[] = [];
try {
  const response = await fetch(`${API_URL}/api/blog/posts?status=published&language=id&limit=100`);
  if (response.ok) {
    posts = await response.json();
    posts.sort((a, b) => (b.publishedAt || 0) - (a.publishedAt || 0));
  }
} catch {
  // API unavailable at build time — render empty state
}
---

<Layout
  title="Blog — Ekajaya"
  description="Tulisan tentang engineering, sistem, dan membangun hal yang berarti."
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en" href="/blog" />
    <link rel="alternate" hreflang="id" href="/id/blog" />
  </Fragment>

  <div class="max-w-7xl mx-auto px-6 py-24 md:py-32">
    <header class="mb-16">
      <p class="font-mono text-xs tracking-[0.3em] text-accent mb-3">BLOG</p>
      <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-6xl font-bold text-foreground">
        Tulisan.
      </h1>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        posts.map((post) => {
          const tags: string[] = (() => {
            try { return JSON.parse(post.tags); } catch { return []; }
          })();
          const pubDate = post.publishedAt ? new Date(post.publishedAt) : null;
          const thumbnailUrl = post.thumbnailKey
            ? `${API_URL}/assets/${post.thumbnailKey}`
            : null;
          return (
            <a href={`/id/blog/${post.slug}/`} class="group block">
              <article class="h-full border border-border rounded-lg overflow-hidden hover:border-accent transition-colors flex flex-col">
                {thumbnailUrl && (
                  <div class="aspect-video overflow-hidden">
                    <img
                      src={thumbnailUrl}
                      alt={post.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-5 flex-1 flex flex-col">
                  <h2 class="text-lg font-bold text-foreground group-hover:text-accent transition-colors mb-2">
                    {post.title}
                  </h2>
                  <p class="text-sm text-muted-foreground leading-relaxed mb-4 flex-1">
                    {post.description}
                  </p>
                  <div class="flex items-center justify-between gap-4 mt-auto">
                    {pubDate && (
                      <time class="font-mono text-xs text-muted-foreground">
                        {pubDate.toLocaleDateString('id-ID', {
                          year: 'numeric',
                          month: 'long',
                          day: 'numeric',
                        })}
                      </time>
                    )}
                    <div class="flex flex-wrap gap-1.5">
                      {tags.slice(0, 3).map((tag) => (
                        <span class="text-[10px] font-mono px-2 py-0.5 border border-border rounded-full text-muted-foreground">
                          {tag}
                        </span>
                      ))}
                      {tags.length > 3 && (
                        <span class="text-[10px] font-mono px-2 py-0.5 text-muted-foreground">
                          +{tags.length - 3}
                        </span>
                      )}
                    </div>
                  </div>
                </div>
              </article>
            </a>
          );
        })
      }
    </div>

    {posts.length === 0 && (
      <p class="text-muted-foreground text-center py-16">Belum ada tulisan. Nantikan segera.</p>
    )}

    <nav class="mt-16 pt-8 border-t border-border text-center">
      <a href="/blog" class="text-sm text-muted-foreground hover:text-foreground transition-colors">English posts →</a>
    </nav>
  </div>
</Layout>
