---
import Layout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const publishedPosts = posts.filter((p) => !p.data.draft);
publishedPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Blog — Work of Ekajaya"
  description="Thoughts on engineering, systems, and building things that matter."
>
  <div class="max-w-3xl mx-auto px-6 py-24 md:py-32">
    <header class="mb-16">
      <p class="font-mono text-xs tracking-[0.3em] text-accent mb-3">BLOG</p>
      <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-6xl font-bold text-foreground">
        Writings.
      </h1>
    </header>

    <div class="space-y-8">
      {
        publishedPosts.map((post) => (
          <article class="group border-b border-border pb-8 hover:border-accent transition-colors">
            <a href={`/blog/${post.id}/`} class="block">
              <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2 mb-2">
                <h2 class="text-lg font-bold text-foreground group-hover:text-accent transition-colors">
                  {post.data.title}
                </h2>
                <time class="font-mono text-xs text-muted-foreground">
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
              </div>
              <p class="text-sm text-muted-foreground leading-relaxed mb-3">
                {post.data.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="text-[10px] font-mono px-2 py-1 border border-border rounded-full text-muted-foreground">
                    {tag}
                  </span>
                ))}
              </div>
            </a>
          </article>
        ))
      }
    </div>

    {publishedPosts.length === 0 && (
      <p class="text-muted-foreground">No posts yet. Check back soon.</p>
    )}
  </div>
</Layout>
