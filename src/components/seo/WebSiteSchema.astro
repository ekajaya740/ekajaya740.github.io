---
import JsonLd from './JsonLd.astro';

const siteUrl = Astro.site?.toString() || 'https://workofekajaya.com';

const websiteData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Work of Ekajaya',
  url: siteUrl,
  description: 'Full-stack engineer building scalable, production-ready web applications with Spring Boot, Node.js, Next.js, Astro, and cloud-native infrastructure.',
  inLanguage: 'en',
  author: {
    '@type': 'Person',
    name: 'I Putu Ekajaya Awidya Putra',
    url: siteUrl,
  },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${siteUrl.replace(/\/$/, '')}/blog/?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};
---

<JsonLd data={websiteData} />
