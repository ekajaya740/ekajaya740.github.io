    "Spring Boot",
    "Node.js",
    "Next.js",
    "Astro",
    "React",
    "TypeScript",
    "PostgreSQL",
    "Docker",
    "Cloud Infrastructure",
    "DevOps",
  ],
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "Stikom Bali Institute of Technology and Business",
  },
  worksFor: [
    {
      "@type": "Organization",
      name: "Re:creation via PT SUM Digital Konsultan",
      jobTitle: "Fullstack Web Developer",
      startDate: "2025-12",
    },
    {
      "@type": "Organization",
      name: "PT SUM Digital Konsultan",
      jobTitle: "Fullstack Web Developer",
      startDate: "2024-10",
    },
  ],
  speaks: [
    { "@type": "Language", name: "English" },
    { "@type": "Language", name: "Indonesian" },
    { "@type": "Language", name: "Japanese" },
  ],
};
---

<JsonLd data={personData} />
