  url: Astro.site?.toString() || "https://workofekajaya.com",
  image: new URL('/og-default.png', Astro.site).toString(),
  sameAs: [
    "https://github.com/ekajaya740",
    "https://profill.link/ekajaya740",
    "https://linkedin.com/in/ekajaya740",
  ],
  address: {
