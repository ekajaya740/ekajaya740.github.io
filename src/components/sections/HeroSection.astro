---
import { WoeHeatmap } from '@/components/react/shaders/WoeHeatmap';
import { Icon } from 'astro-icon/components';
---

<section id="hero" class="relative w-full h-screen overflow-hidden">
  <div class="absolute inset-0 z-0 h-full">
    <WoeHeatmap client:only="react" />
  </div>

  <div class="absolute inset-0 z-10 flex flex-col items-start justify-end pb-24 md:pb-32 px-6 md:px-16 pointer-events-none">
    <div class="text-left pointer-events-auto max-w-2xl">
      <p class="font-mono text-xs md:text-sm tracking-[0.3em] text-muted-foreground mb-3">
        FULL-STACK ENGINEER — BALI, INDONESIA
      </p>

      <h1 class="font-[family-name:var(--font-display)] text-3xl md:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight text-foreground text-balance">
        I Putu Ekajaya<br/>Awidya Putra
      </h1>

      <p class="mt-6 text-base md:text-lg text-muted-foreground max-w-lg leading-relaxed text-pretty">
        Building production-ready web applications with Spring Boot, Node.js, Next.js, Astro, and cloud-native infrastructure.
      </p>

      <div class="mt-8 flex items-center gap-4">
        <a
          href="#about"
          class="px-6 py-3 bg-foreground text-background rounded-md font-mono text-sm font-medium active:scale-[0.96] transition-transform"
        >
          Explore
        </a>
        <a
          href="/pdf/resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-3 border border-border rounded-md font-mono text-sm font-medium hover:bg-secondary hover:border-foreground active:scale-[0.96] transition-colors"
        >
          <Icon name="lucide:file-text" size={14} class="inline-block align-middle mr-1" />
          CV
        </a>
        <a
          href="https://github.com/ekajaya740"
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-3 border border-border rounded-md font-mono text-sm font-medium hover:bg-secondary hover:border-foreground active:scale-[0.96] transition-colors"
        >
          GitHub
        </a>
      </div>
    </div>
  </div>
</section>